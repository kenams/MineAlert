# MineAlert environment template
# Copy to .env.local for local development, or configure the same variables in Vercel.

# Supabase
# Public Supabase project URL used by the browser, middleware and server components.
NEXT_PUBLIC_SUPABASE_URL=
# Public Supabase publishable key exposed to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only Supabase service role key for scrapers, seeds and admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# Auth
# Canonical public app URL used to build OAuth and auth callback redirects.
NEXT_PUBLIC_SITE_URL=

# Scraper / Cron
# Shared secret required by /api/scraper through Authorization: Bearer <secret> or X-Cron-Secret.
CRON_SECRET=
# Enables the local/server-side auto sync worker.
SCRAPER_AUTO_SYNC_ENABLED=true
# Triggers an immediate sync when the worker starts.
SCRAPER_BOOT_SYNC_ENABLED=true
# Optional explicit base URL called by the auto sync worker. Defaults to NEXT_PUBLIC_SITE_URL in dev and must be explicit or derivable in prod.
SCRAPER_BASE_URL=
# Cron expression used by the local/server-side auto sync worker.
SCRAPER_CRON_EXPRESSION=*/5 * * * *

# Email
# Optional Resend API key for alert emails. Leave empty to disable email sending cleanly.
RESEND_API_KEY=

# Deprecated compatibility aliases
# Keep these empty unless you are migrating an older deployment. Prefer the active variables above.

# Deprecated: use NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY instead.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Deprecated: use SUPABASE_SERVICE_ROLE_KEY instead.
# SUPABASE_SERVICE_KEY=
# Deprecated: use NEXT_PUBLIC_SITE_URL instead.
# NEXT_PUBLIC_APP_URL=
# Deprecated: use SCRAPER_BASE_URL instead.
# SCRAPER_INTERNAL_URL=
# Deprecated: use SCRAPER_CRON_EXPRESSION instead.
# SCRAPER_SYNC_CRON=
